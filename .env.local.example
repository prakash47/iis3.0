# Sanity CMS - copy this file to `.env.local` and fill in the values from your
# free Sanity project. Also set the SAME values in Vercel (Project Settings ->
# Environment Variables) before deploying.
#
# WHICH ARE PUBLIC vs SECRET:
#  - The three NEXT_PUBLIC_* values are PUBLIC identifiers (they ship in the
#    browser bundle by design) - safe to share.
#  - SANITY_REVALIDATE_SECRET is a SECRET you generate yourself. Set it here and
#    on the Sanity webhook. NEVER paste it into a chat and NEVER prefix a secret
#    with NEXT_PUBLIC_.

# From your Sanity project (Manage -> Project settings). Public.
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Keep "production" (a PUBLIC dataset = no token needed = simplest setup).
NEXT_PUBLIC_SANITY_DATASET=production

# A pinned API date. Leave as-is unless you deliberately bump it.
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# A random string YOU choose (e.g. from a password manager). Put the SAME string
# on the Sanity webhook (Manage -> API -> Webhooks -> Secret). Server-only secret.
SANITY_REVALIDATE_SECRET=

# Only if you make the dataset PRIVATE instead of public (not recommended for a
# public blog). A read token from Manage -> API -> Tokens. Server-only secret.
# SANITY_API_READ_TOKEN=

# ── Deployment: canonical host + indexing ───────────────────────────────────
# The site's canonical base URL. LEAVE BLANK for local dev (it falls back to the
# production domain). On a NON-production deployment, set it to THAT deployment's
# own URL so canonicals / sitemap / OG / JSON-LD never point at the live site:
#   staging     -> https://staging.intentioninfoservice.com  (or the *.vercel.app URL)
#   production  -> https://www.intentioninfoservice.com       (or leave blank)
# Public (NEXT_PUBLIC_). No trailing slash.
NEXT_PUBLIC_SITE_URL=

# Search-engine indexing is OFF unless this is exactly the string "true". Set it
# to "true" ONLY on the real production (www) deployment. Leave it blank/unset
# everywhere else (local, *.vercel.app, staging.*) so those stay noindex with a
# robots "Disallow: /". Forgetting it fails safe (noindex, never over-index). Public.
NEXT_PUBLIC_SITE_INDEXABLE=
